# Renombra este archivo a .env.local y llena los valores
# NUNCA subas .env.local a GitHub

# Supabase → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─── IA ───────────────────────────────────────────────────
# PRODUCCIÓN: usar el proxy. La app llama a esta URL con el JWT del
# usuario; la key de OpenAI vive SOLO en el servidor (supabase secrets).
EXPO_PUBLIC_AI_PROXY_URL=https://XXXXXXXXXX.functions.supabase.co/ai-proxy

# DESARROLLO solamente: fallback directo a OpenAI si no hay proxy.
# ⚠️ NO incluir esta key en builds de producción (queda expuesta en el bundle).
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-...

# ─── Secretos del SERVIDOR (NO van aquí, se configuran con la CLI) ───
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set AI_DAILY_LIMIT=50
