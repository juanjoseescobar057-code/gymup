{
  "expo": {
    "name": "GymUp",
    "slug": "gymup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "gymup",
    "backgroundColor": "#0e0e10",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymup.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GymUp necesita la cámara para analizar tus comidas y corregir tu postura.",
        "NSPhotoLibraryUsageDescription": "GymUp necesita acceso a tus fotos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e10"
      },
      "package": "com.gymup.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "GymUp necesita la cámara para analizar tus comidas y corregir tu postura."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "GymUp usa la cámara para contar tus reps y corregir tu técnica en tiempo real.",
          "enableMicrophonePermission": false,
          "enableFrameProcessors": true
        }
      ],
      "react-native-fast-tflite",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0e0e10"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#c8ff3e"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e76f774a-81e4-4795-b5ff-840949109629"
      }
    },
    "owner": "juanesco22"
  }
}
